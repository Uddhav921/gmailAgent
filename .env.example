# ─── Google OAuth ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ─── Gemini (LLM) ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── MongoDB ────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/gmailAgent

# ─── Redis (Upstash) ────────────────────────────────────────────
REDIS_URL=rediss://default:password@your-upstash-url:6380

# ─── Supermemory ────────────────────────────────────────────────
SUPERMEMORY_API_KEY=your_supermemory_api_key

# ─── App Config ─────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ─── Gmail Pub/Sub ──────────────────────────────────────────────
PUBSUB_TOPIC=projects/your-project-id/topics/gmail-notifications
GMAIL_WEBHOOK_SECRET=your_random_webhook_secret
